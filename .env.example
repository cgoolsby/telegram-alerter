# Copy to .env and fill in real values — .env is gitignored, never commit it.
# install.sh sources .env automatically if present.

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your chat id (see README: getUpdates)
TELEGRAM_CHAT_ID=

# Bearer token callers must send to /send (generate: openssl rand -hex 32)
AUTH_TOKEN=

# Image ref your cluster can pull, e.g. ghcr.io/you/telegram-alerter:v1
IMAGE=
